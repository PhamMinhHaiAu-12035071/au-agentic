{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "gen:manifest": {
      "inputs": [
        "scripts/generate-template-manifest.ts",
        "../templates/**/*.md",
        "../templates/**/LICENSE"
      ],
      "outputs": ["src/generated/**"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build", "gen:manifest"],
      "outputs": ["dist/**"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json", "../../tsconfig.json"]
    },
    "typecheck": {
      "dependsOn": ["^build", "gen:manifest"],
      "outputs": [".tsbuildinfo"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig.json", "../../tsconfig.json"]
    },
    "test": {
      "dependsOn": ["^build", "gen:manifest"],
      "outputs": ["coverage/**"],
      "inputs": ["$TURBO_DEFAULT$", "../../bunfig.toml"],
      "env": ["CI"]
    },
    "lint": {
      "outputs": [],
      "inputs": ["$TURBO_DEFAULT$", "../../biome.json"]
    },
    "format": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
